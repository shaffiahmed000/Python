n=int(input("Enter no of teams:"))
teams=[]
match=[]
for i in range(1,n+1):
    team=input("enter team {i}:")
    teams.append(team)


for i in range (n-1):
    for j in range(i+1,n):
        match.append([teams[i],teams[j]])
        pos=1
for i in match:
    print("MATCH {}.{} vs {}".format(pos,i[0],i[1]))
    pos=pos+1
