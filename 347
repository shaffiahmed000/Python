class Solution:
    def topKFrequent(self, nums: List[int], k: int) -> List[int]:
        l=[]
        d={}
        for i in nums:
            d[i]=d.get(i,0)+1
        res=dict(sorted(d.items(),key=lambda x:x[1],reverse=True))
        for i in res:
            if len(l)>=k:
                break
            l.append(i)
        return l
